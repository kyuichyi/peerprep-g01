# Use Node instead of Nginx for development
FROM node:lts-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy package files and install dependencies
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Copy source code
COPY . .

# Vite's default dev port
EXPOSE 5173

CMD ["pnpm", "dev", "--host"]